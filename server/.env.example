# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/medquad?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Client (Frontend) URL ────────────────────────────────
# Set this to your Vercel URL or medquadhealth.com
CLIENT_URL=https://medquadhealth.com

# ─── Google Gemini AI ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
